# tar.jqtest -- test corpus for tar.jq

# tar: empty archive (two 512-byte zero blocks) -- no entries
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,linkname,data}]
""
[]

# tar: single regular file "hello.txt" containing "Hello, world!" (13 bytes)
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,linkname,data}]
""
[{"name":"hello.txt","type":"0","size":13,"linkname":"","data":[72,101,108,108,111,44,32,119,111,114,108,100,33]}]

# tar: data decoded as a string
include "b64"; include "tar"; tar_entries_from_stream(b64_stream_decode) | .data | implode
""
"Hello, world!"

# tar: directory entry (typeflag "5", size 0, trailing slash in name)
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,linkname,data}]
""
[{"name":"mydir/","type":"5","size":0,"linkname":"","data":[]}]

# tar: symbolic link (typeflag "2", linkname carries the target)
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,linkname,data}]
""
[{"name":"link.txt","type":"2","size":0,"linkname":"hello.txt","data":[]}]

# tar: multi-entry archive -- regular file + directory + symlink in order
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,linkname,data}]
""
[{"name":"hello.txt","type":"0","size":13,"linkname":"","data":[72,101,108,108,111,44,32,119,111,114,108,100,33]},{"name":"mydir/","type":"5","size":0,"linkname":"","data":[]},{"name":"link.txt","type":"2","size":0,"linkname":"hello.txt","data":[]}]

# tar: GNU long name (typeflag "L") -- 109-char path resolved transparently
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,data}]
""
[{"name":"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa/file.txt","type":"0","size":4,"data":[100,101,101,112]}]

# tar: compose with gzip_from_stream for .tar.gz
include "b64"; include "gzip"; include "tar"; [tar_entries_from_stream(gzip_from_stream(b64_stream_decode)) | {name,type,size,data}]
"H4sIAAAAAAAAA8tIzcnJ1yupKGGgHTAAAjMTEzANBOi0gYGhKYINEjc0NAEKKRjQ0E1wUFpcklgEtL4oPx9vGBCSH6LAAxT/Ogrl+UU5KYoD7ZhRMApGwSgYBXQDAMWe8rgACAAA"
[{"name":"hello.txt","type":"0","size":13,"data":[72,101,108,108,111,44,32,119,111,114,108,100,33]}]

# tar: truncated -- no EOF trailer at all; completed entries still emitted
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,data}]
""
[{"name":"hello.txt","type":"0","size":13,"data":[72,101,108,108,111,44,32,119,111,114,108,100,33]}]

# tar: truncated -- one zero block instead of two; same result
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,data}]
""
[{"name":"hello.txt","type":"0","size":13,"data":[72,101,108,108,111,44,32,119,111,114,108,100,33]}]

# tar: truncated -- partial zero block mid-trailer; same result
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode) | {name,type,size,data}]
""
[{"name":"hello.txt","type":"0","size":13,"data":[72,101,108,108,111,44,32,119,111,114,108,100,33]}]

# tar: truncated -- completely empty byte stream; no entries
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode)]
""
[]

# tar: collectData=false -- headers emitted immediately, data skipped (O(1) memory per entry)
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode; false) | {name,type,size,data}]
""
[{"name":"hello.txt","type":"0","size":13,"data":[]}]

# tar: collectData predicate -- only collect data for entries with size > 0
include "b64"; include "tar"; [tar_entries_from_stream(b64_stream_decode; .size > 0) | {name,type,size,data}]
""
[{"name":"hello.txt","type":"0","size":13,"data":[72,101,108,108,111,44,32,119,111,114,108,100,33]},{"name":"mydir/","type":"5","size":0,"data":[]},{"name":"link.txt","type":"2","size":0,"data":[]}]
