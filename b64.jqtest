# b64_tests.jq — test corpus for b64.jq

# b64val: A → 0,  Z → 25
include "b64"; b64val
65
0

include "b64"; b64val
90
25

# b64val: a → 26,  z → 51
include "b64"; b64val
97
26

include "b64"; b64val
122
51

# b64val: 0 → 52,  9 → 61
include "b64"; b64val
48
52

include "b64"; b64val
57
61

# b64val: + → 62,  / → 63
include "b64"; b64val
43
62

include "b64"; b64val
47
63

# b64val: = → -1 (padding sentinel)
include "b64"; b64val
61
-1

# b64_stream_decode: empty string → empty array
include "b64"; [b64_stream_decode]
""
[]

# b64_stream_decode: "AA==" → one null byte
include "b64"; [b64_stream_decode]
"AA=="
[0]

# b64_stream_decode: "AQ==" → 0x01
include "b64"; [b64_stream_decode]
"AQ=="
[1]

# b64_stream_decode: "/w==" → 0xFF (high byte — no UTF-8 mangling)
include "b64"; [b64_stream_decode]
"/w=="
[255]

# b64_stream_decode: "AAA=" → two bytes [0, 0]
include "b64"; [b64_stream_decode]
"AAA="
[0,0]

# b64_stream_decode: "AAEC" → three bytes [0, 1, 2] (no padding)
include "b64"; [b64_stream_decode]
"AAEC"
[0,1,2]

# b64_stream_decode: high bytes across a group boundary — 0xFF 0xFE 0xFD
include "b64"; [b64_stream_decode]
"//79"
[255,254,253]

# b64_stream_decode: one full group + one padded → 4 bytes
include "b64"; [b64_stream_decode]
"AAAAAA=="
[0,0,0,0]

# b64_stream_decode: two full groups → 6 bytes
include "b64"; [b64_stream_decode]
"AAAAAAAA"
[0,0,0,0,0,0]

# ── Multi-group real-world inputs ─────────────────────────────────────────

# Docker image config (compact JSON) — 451 bytes, 7 streaming blocks + 1 final
include "b64"; [b64_stream_decode] | length
""
451

include "b64"; [b64_stream_decode] | .[0]
""
123

# Docker image config (pretty-printed JSON) — 396 bytes, 6 streaming blocks + 1 final
include "b64"; [b64_stream_decode] | length
""
396

include "b64"; [b64_stream_decode] | .[0:3]
""
[123,10,9]

# Gzip binary data — 117 bytes, 1 streaming block + 1 final; bytes > 127 test UTF-8 safety
# First two bytes are the gzip magic number: 0x1f=31, 0x8b=139 (both high bytes)
include "b64"; [b64_stream_decode] | .[0:2]
"H4sIAAAAAAACAyspKk1loDEwAAJTU1MwDQTotIGhuQmcDRE3MzM0YlAwYKADKC0uSSxSUGAYoaDe1ceNiZERzmdisGMA8SoYHMB8Byx6HBgsGGA6QDQrmiwyXQPl1cDlIUG9wYaflWEUDDgAAIAGdJIABAAA"
[31,139]

include "b64"; [b64_stream_decode] | length
"H4sIAAAAAAACAyspKk1loDEwAAJTU1MwDQTotIGhuQmcDRE3MzM0YlAwYKADKC0uSSxSUGAYoaDe1ceNiZERzmdisGMA8SoYHMB8Byx6HBgsGGA6QDQrmiwyXQPl1cDlIUG9wYaflWEUDDgAAIAGdJIABAAA"
117

# ── b64_stream_encode ──────────────────────────────────────────────────────

# b64_stream_encode: empty input → empty string (wrap=0 always emits one string)
include "b64"; b64_stream_encode(empty)
null
""

# b64_stream_encode: empty input + wrap=76 → no output
include "b64"; [b64_stream_encode(empty; 76)]
null
[]

# b64_stream_encode: [0] → "AA=="
include "b64"; b64_stream_encode(.[])
[0]
"AA=="

# b64_stream_encode: [1] → "AQ=="
include "b64"; b64_stream_encode(.[])
[1]
"AQ=="

# b64_stream_encode: [255] → "/w==" (high byte — no UTF-8 mangling)
include "b64"; b64_stream_encode(.[])
[255]
"/w=="

# b64_stream_encode: [0, 0] → "AAA="
include "b64"; b64_stream_encode(.[])
[0,0]
"AAA="

# b64_stream_encode: [0, 1, 2] → "AAEC"
include "b64"; b64_stream_encode(.[])
[0,1,2]
"AAEC"

# b64_stream_encode: high bytes across a group boundary — 0xFF 0xFE 0xFD
include "b64"; b64_stream_encode(.[])
[255,254,253]
"//79"

# b64_stream_encode: one full group + one padded → "AAAAAA=="
include "b64"; b64_stream_encode(.[])
[0,0,0,0]
"AAAAAA=="

# b64_stream_encode: two full groups → "AAAAAAAA"
include "b64"; b64_stream_encode(.[])
[0,0,0,0,0,0]
"AAAAAAAA"

# b64_stream_encode: wrap=3 matches base64 -w3 (non-multiple-of-4 wrap)
# base64 -w3 <<< 'foo' → "Zm9\nvCg\n=="
include "b64"; [b64_stream_encode(.[]; 3)]
[102,111,111,10]
["Zm9","vCg","=="]

# b64_stream_encode: wrap=4, two groups on separate lines
include "b64"; [b64_stream_encode(.[]; 4)]
[0,0,0,0,0,0]
["AAAA","AAAA"]

# b64_stream_encode: round-trip with b64_stream_decode → original string
include "b64"; b64_stream_encode(b64_stream_decode)
"SGVsbG8sIHdvcmxkIQ=="
"SGVsbG8sIHdvcmxkIQ=="

# b64_stream_encode: round-trip with Docker image config — 451 bytes
include "b64"; b64_stream_encode(b64_stream_decode)
""
""
